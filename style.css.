*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:#0f1720;font-family:Arial,Helvetica,sans-serif}
#game{display:block;width:100%;height:100vh;background:linear-gradient(#1e293b,#0b1220)}
#ui{position:absolute;left:10px;top:10px;color:#fff;z-index:10}
#score{font-weight:bold;font-size:18px}
#high{font-size:14px;opacity:0.8}
#overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:20}
.hidden{display:none}
#gameover{color:#fff;font-size:36px;margin-bottom:12px}
#retry{padding:10px 18px;font-size:16px;border-radius:8px;border:none;background:#06b6d4;color:#042029}
